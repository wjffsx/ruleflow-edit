{
  "name": "ruleflow-edit",
  "version": "0.3.0",
  "type": "module",
  "description": "Visual rule chain editor for IIoT and VPP scenarios, built with Preact and LogicFlow",
  "license": "MIT",
  "author": "RuleFlow Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/wjffsx/ruleflow-edit.git"
  },
  "bugs": {
    "url": "https://github.com/wjffsx/ruleflow-edit/issues"
  },
  "homepage": "https://github.com/wjffsx/ruleflow-edit#readme",
  "keywords": [
    "ruleflow",
    "rule-engine",
    "visual-editor",
    "flow-editor",
    "logicflow",
    "preact",
    "iiot",
    "vpp",
    "virtual-power-plant",
    "drag-and-drop"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/src/index.d.ts"
    },
    "./view": {
      "import": "./dist/view.es.js",
      "require": "./dist/view.cjs.js",
      "types": "./dist/src/view.d.ts"
    },
    "./dist/ruleflow-edit.css": "./dist/ruleflow-edit.css",
    "./dist/view.css": "./dist/view.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-view-css.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "pre-push": "pwsh -File scripts/pre-push-check.ps1",
    "pre-push:fix": "pwsh -File scripts/pre-push-check.ps1 -Fix",
    "pre-push:quick": "pwsh -File scripts/pre-push-check.ps1 -SkipTests -SkipBuild"
  },
  "dependencies": {
    "fuse.js": "^7.4.2",
    "hotkeys-js": "^4.0.4",
    "js-yaml": "^4.2.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@logicflow/core": "^2.2.3",
    "@logicflow/extension": "^2.2.3",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/preact": "^3.2.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "lucide-preact": "^1.21.0",
    "preact": "^10.29.2",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@logicflow/core": "^2.0.0",
    "@logicflow/extension": "^2.0.0",
    "@preact/signals": "^2.0.0",
    "lucide-preact": "^1.0.0",
    "preact": "^10.0.0"
  }
}
